# Anthropic API key
# Получить на https://console.anthropic.com или через прокси kiro.cheap (дешевле)
ANTHROPIC_API_KEY=sk-ant-...

# Base URL (опционально)
# Для официального Anthropic API — не нужен (оставь закомментированным)
# Для kiro.cheap (прокси, дешевле) — раскомментируй:
# ANTHROPIC_BASE_URL=https://api.kiro.cheap